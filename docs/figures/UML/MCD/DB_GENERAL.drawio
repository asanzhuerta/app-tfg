                </mxCell>
                <mxCell id="db-final-note-2" value="Las integraciones SMTP y Web Push se registran en M7, mientras que las suscripciones de dispositivo pertenecen a M6 porque dependen del usuario receptor de avisos." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#1f2937;" parent="1" vertex="1">

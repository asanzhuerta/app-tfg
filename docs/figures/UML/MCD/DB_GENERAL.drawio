                <mxCell id="db-final-note-1" value="users es la identidad transversal. M2 extiende usuarios para clientes y comerciales. M4, M5, M6 y M7 reutilizan clientes, usuarios y catálogo mediante claves foráneas." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#1f2937;" parent="1" vertex="1">

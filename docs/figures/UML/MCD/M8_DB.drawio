                <mxCell id="m8-final-title" value="M8 - Modelo final de datos" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#222222;" parent="1" vertex="1">
                    <mxGeometry x="40" y="30" width="900" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="m8-final-subtitle" value="El esquema final desplegado no incorpora tablas persistentes propias para M8. La funcionalidad queda fuera del alcance de la base de datos implementada." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8f9fa;strokeColor=#d0d7de;fontSize=11;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="40" y="70" width="900" height="36" as="geometry"/>
                </mxCell>
                <mxCell id="m8-final-legend" value="Verde = clave primaria. Rojo = clave foranea. Amarillo = entidad externa referenciada desde otro módulo." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#f8f9fa;strokeColor=#d0d7de;fontSize=11;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="680" y="30" width="470" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="m8-final-note-1" value="Sin entidades persistentes propias en el modelo final actual. Si se implementa M8 mas adelante, este módulo deberia ampliarse con sus tablas específicas y sus relaciones hacia users/clients/products según corresponda." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#1f2937;" parent="1" vertex="1">
                    <mxGeometry x="80" y="140" width="720" height="120" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>

{
  "name": "kinestilistas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rimraf .next && next dev --webpack",
    "dev:clean": "rimraf .next && rimraf node_modules/.cache && next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "build:clean": "rimraf .next && next build --webpack",
    "start:clean": "rimraf .next && next build --webpack && next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "quality:react-doctor": "npx -y react-doctor@latest app --verbose --no-score",
    "quality:wave": "node ./scripts/wave-audit.mjs",
    "quality:ui": "node ./scripts/run-test-suite.mjs quality:react-doctor quality:wave",
    "test:static": "node ./scripts/run-test-suite.mjs typecheck lint build",
    "test:business": "node ./scripts/business-critical-suite.mjs",
    "test:modules": "node ./scripts/run-test-suite.mjs test:m1-m3:foundation test:m4 test:m5 test:m6 test:m7",
    "test:all": "node ./scripts/run-test-suite.mjs test:static migration:run test:modules quality:ui",
    "test:m1-m3:foundation": "cross-env CLIENT_DEBUG=false TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m1-m3-foundation-test.ts",
    "test:m2:route-points": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m2-route-points-test.ts",
    "test:m4": "node ./scripts/run-test-suite.mjs test:m4:orders-delivery test:m4:payments",
    "test:m4:full": "node ./scripts/run-test-suite.mjs test:m4 test:m4:ui",
    "test:m4:orders-delivery": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m4-orders-delivery-test.ts",
    "test:m4:payments": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m4-payments-test.ts",
    "test:m4:ui": "node ./scripts/m4-orders-ui-check.mjs",
    "test:m5": "node ./scripts/run-test-suite.mjs test:m5:technical-email test:m5:service-templates test:m5:visual-results",
    "test:m5:technical-email": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m5-technical-email-test.ts",
    "test:m5:service-templates": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m5-service-templates-test.ts",
    "test:m5:visual-results": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m5-salon-visual-results-test.ts",
    "test:m6": "node ./scripts/run-test-suite.mjs test:m6:communications test:m6:promotions test:m6:client-tiers",
    "test:m6:communications": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m6-communications-test.ts",
    "test:m6:promotions": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m6-promotion-discount-test.ts",
    "test:m6:client-tiers": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m6-client-tier-test.ts",
    "test:m7": "node ./scripts/run-test-suite.mjs test:m7:integrations test:m7:support test:m7:operations test:m7:audit-export test:m7:rate-limits test:m7:operations-report test:m7:enterprise-operations",
    "test:m7:integrations": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-integrations-test.ts",
    "test:m7:support": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-support-test.ts",
    "test:m7:operations": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-operations-test.ts",
    "test:m7:audit-export": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-audit-export-test.ts",
    "test:m7:rate-limits": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-rate-limit-test.ts",
    "test:m7:operations-report": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-operations-report-test.ts",
    "test:m7:enterprise-operations": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-enterprise-operations-test.ts",
    "catalog:upload-product-images": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/upload-product-images.ts",
    "db:backup-data": "node ./scripts/backup-data-only.mjs",
    "db:restore-data": "node ./scripts/restore-data-only.mjs",
    "db:prepare-demo": "node ./scripts/prepare-demo-data.mjs",
    "typeorm:cli": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm:ds": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d ./lib/typeorm/data-source-cli.ts",
    "migration:create": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json npm run typeorm:cli -- migration:create",
    "migration:generate": "npm run typeorm:ds -- migration:generate",
    "migration:run": "npm run typeorm:ds -- migration:run",
    "migration:revert": "npm run typeorm:ds -- migration:revert",
    "migration:show": "npm run typeorm:ds -- migration:show"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "typeorm": "^0.3.28",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.11",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5"
  }
}
